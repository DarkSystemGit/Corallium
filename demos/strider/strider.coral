                    cactus_data[i].x=cactus_data[i].x-speed;
                };
                if((frame%(10 as i32))==(0 as i32)){

                if (cactus_data[i].tilemap[0]==5){

                    cactus_data[i].tilemap[0]=6;

                }else{
                if (cactus_data[i].tilemap[0]==6){

                     cactus_data[i].tilemap[0]=5;

                };};};
                if((frame%(random(rand_ptr,0,4) as i32))==(0 as i32)){

                if (cactus_data[i].tilemap[0]==9){

                    cactus_data[i].y=cactus_data[i].y+2;};
                    if(cactus_data[i].y>184){
                        gfx::removeSprite(cactus_data[i]);


                        mem::free(cactus_data[i].tilemap as &void);
                         mem::free(cactus_data[i] as &void);


                        cactus_data[i]=(None as gfx::Sprite);
                    };

                };
                if(sprites_collide(cactus_data[i],player)){
                   dead=true;
                };
                if(cactus_data[i].x<(-16)){
                    gfx::removeSprite(cactus_data[i]);


                    mem::free(cactus_data[i].tilemap as &void);
                     mem::free(cactus_data[i] as &void);


                    cactus_data[i]=(None as gfx::Sprite);
                };
            };
        };
        gfx::pullControls(controls);
        if((controls[0]==true)&(player_accel>-0.1)&(player_accel<0.1)&(py_float>150.0)){
            player_accel=player_accel-2.0;
        };
        if(player_accel!=0.0){
            player_accel=player_accel+0.05;
        };
        if(py_float>168.0){
            py_float=168.0;
            player_accel=0.0;
        };
        py_float=py_float+player_accel;
        player.y=(py_float as i16);
        frame=frame+(1 as i32);
        if(dead){
            break;
        };
    };
    player.tilemap=[50];
    let dead_anim: bool=false;
    while(controls[8]==false){
        gfx::render();
        gfx::pullControls(controls);
        if(dead_anim==false){
            let ds: i16=10;
            for(let i: i16=0; i<(150/ds); i=i+1){
                py_float=py_float-(0.5*(((150.0/(ds as f32))-i as f32)/(150.0/(ds as f32)))+0.1);
             player.y=(py_float as i16);
             gfx::render();
        };
        for(let i: i16=0; i<(250/ds); i=i+1){
            py_float=py_float+(1.0-(((250.0/(ds as f32))-i as f32)/(250.0/(ds as f32))));
             player.y=(py_float as i16);
             gfx::render();
        };
        gfx::removeLayer(sun);
        gfx::removeLayer(uiLayer);
        gfx::removeSprite(cloudLayer);
        gfx::removeSprite(cloudLayerTwo);
        gfx::removeSprite(player);
        gfx::removeSprite(ground);
        gfx::removeSprite(groundTwo);
        for(let i:i16=0;i<10;i=i+1){
            if(cactus_data[i]!=(None as gfx::Sprite)){
                gfx::removeSprite(cactus_data[i]);
                mem::free(cactus_data[i].tilemap as &void);
                mem::free(cactus_data[i] as &void);
            };
        };
        bgLayer.tilemap=game_over_Tilemap;
        dead_anim=true;
        };
    };
    return;
}
