    };
    let player: gfx::Sprite=gfx::Sprite{
        id:4,
        x:148,
        y: 168,
        tilemap_height:1,
        tilemap_width: 1,
        tilemap: [47],
        scale_x: 3.0,
        scale_y: 3.0,
