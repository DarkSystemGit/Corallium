                    cactus_data[spawn_slot] = buf as gfx::Sprite;
                    gfx::registerSprite(cactus_data[spawn_slot]);

                    next_id = next_id + 1;
                    lf = frame;
                    }else{
                        if(rand%3!=0){
                        if((frame - lf) > ((48/speed) as i32)){
                            let tileBuf: [i16] = mem::alloc(1 as i32) as [i16];
                            tileBuf[0] = 5;
                            let sprite: gfx::Sprite = gfx::Sprite {
                            id: next_id,
