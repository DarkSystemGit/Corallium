                            x: 320,
                            y: 120,
                            tilemap_height: 1,
                            tilemap_width: 1,
                            tilemap: tileBuf,
                            scale_x: 2.0,
                            scale_y: 2.0,
                            };

                            let buf: &void = mem::alloc(12 as i32);
                            mem::copy(sprite as &void, buf, 12 as i32, 0 as i32);
                            cactus_data[spawn_slot] = buf as gfx::Sprite;
                            gfx::registerSprite(cactus_data[spawn_slot]);
                            next_id = next_id + 1;
                            lf = frame;
                        };
                    }else{
