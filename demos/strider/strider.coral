    gfx::registerLayer(uiLayer);
       let rand_ptr: &i32=init_rand();

    let cactus_slots: Buffer=Buffer{data: [(None as gfx::Sprite);30] as &void, len: 30};
    let next_slot: i16=0;
    let lf: i32=0;
    let next_id: i16=5;
    let frame: i32=0 as i32;
    let cactus_data: [gfx::Sprite]=(cactus_slots.data) as [gfx::Sprite];

    let dead: bool=false;
    while (true){
        gfx::render();
        get_score_tiles((frame as i16/2) as i16,8,ui);
        let rand: i16=random(rand_ptr,0,1000);
        let speed: i16=((1.0*((frame as f32)/(5000 as f32))+1.0) as i16);
        let spawn_slot: i16 = -1;
                for (let i: i16 = 0; i < 30; i = i + 1) {
                    if ((spawn_slot == -1) & (cactus_data[i] == (None as gfx::Sprite))) {
                        spawn_slot = i;
                    };
                };


                if (((rand % 100) == 0) & (spawn_slot != -1) & ((frame - lf) > ((16/speed) as i32))) {
                    rand=random(rand_ptr,0,1000);
                    if((rand%5)!=0){
                    let tile: i16 = match (rand % 3) {
                        0 -> 8,
                        _ -> 7
                    };

                    let tileBuf: [i16] = mem::alloc(1 as i32) as [i16];
                    tileBuf[0] = tile;

                    let sprite: gfx::Sprite = gfx::Sprite {
                        id: next_id,
                        priority: 3,
                        x: 320,
                        y: 176,
                        tilemap_height: 1,
                        tilemap_width: 1,
                        tilemap: tileBuf,
                        scale_x: 2.0,
                        scale_y: 2.0,
                    };

                    let buf: &void = mem::alloc(12 as i32);
