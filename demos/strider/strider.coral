fn init_rand() -> &i32 {
    let seed_ptr: [i32] = mem::alloc(2 as i32) as [i32];
    seed_ptr[0]=clock::read()+(1 as i32);
    return seed_ptr as &i32;
}

fn random(seed_ptr: &i32, start: i16, end: i16) -> i16 {
    let seed: [i32] = seed_ptr as [i32];
    let state: i32 = seed[0] % (32768 as i32);
    if (state < (0 as i32)) {
        state = state + (32768 as i32);
    };
    let next_state: i32 =
        ((state * (25173 as i32)) + (13849 as i32)) % (32768 as i32);
    let n: i16 = next_state as i16;
    seed[0] = next_state;
    let range: i16 = end - start + (1 as i16);
    if (range <= 0 as i16) {
        return start;
    };
    return start + (n % range);
}
fn get_score_tiles(score: i16,offset: i16, buf: [i16])->void{
    for (let i: i16=5;i>=0;i=i-1){
        let digit: i16 = score % 10;
        score=score/10;
        buf[i+offset]=10+digit;
    };
    return;
}
fn sprites_collide(a: gfx::Sprite,b: gfx::Sprite)->bool{
    let check1: bool = (a.x as f32)<(b.x as f32+((b.tilemap_width as f32)*8.0*b.scale_x));
        let check2: bool = ((a.x as f32+((a.tilemap_width as f32)*8.0*a.scale_x))>(b.x as f32));
        let check3: bool = ((a.y as f32)<((b.y as f32)+((b.tilemap_height as f32)*8.0*b.scale_y)));
        let check4: bool = ((a.y as f32+((a.tilemap_height as f32)*8.0*a.scale_y))>(b.y as f32));
        let collide: bool = check1 & check2 & check3 & check4;

  return collide;
}
struct Buffer{
    data: &void,
    len: i16
}

